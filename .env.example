# AI Clipper Environment Variables

# IMPORTANT: These are default values. API keys should be entered by users in the application UI.
# These values are only used for development/testing purposes.

# Gemini API Key
# Get your free key from: https://makersuite.google.com/app/apikey
# Users will be prompted to enter this key when they first open the app
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Optional)
# Used for additional AI features
# Get your key from: https://platform.openai.com/api-keys
# Users can enter this in Settings (optional)
OPENAI_API_KEY=

# Backend Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Video Processing Configuration
CACHE_DIR=./cache
TEMP_DIR=./temp
DOWNLOAD_DIR=./downloads

# Whisper Configuration
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# Gemini Configuration
GEMINI_MODEL=gemini-pro
GEMINI_TEMPERATURE=0.7

# Processing Configuration
MAX_VIDEO_DURATION=7200
MAX_CLIPS_PER_VIDEO=10
DEFAULT_CLIP_DURATION=30

# Output Configuration
OUTPUT_FORMAT=mp4
OUTPUT_CODEC=libx264
OUTPUT_PRESET=medium
OUTPUT_QUALITY=high
OUTPUT_ASPECT_RATIO=9:16

# FFmpeg Configuration
FFMPEG_PATH=ffmpeg
FFMPEG_THREADS=4

# WebSocket Configuration
WS_HOST=0.0.0.0
WS_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ai-clipper.log

# Application Configuration
APP_NAME=AI Clipper
APP_VERSION=1.0.0
DEBUG=False
